DISCORD_BOT_TOKEN=your_bot_token_here
# Рекомендуется: ID вашего сервера — slash-команды появятся сразу (иначе глобальная регистрация до ~1 часа).
# Команды будут видны только на этом сервере, пока указан DISCORD_GUILD_ID.
# DISCORD_GUILD_ID=123456789012345678
# Приглашение бота: scope applications.commands + bot
# Включите в Discord Developer Portal → Bot → Message Content Intent (для !aa / !animeadd в чате).
# Чтобы отключить запрос этого intent в коде (только slash): DISCORD_MESSAGE_CONTENT_INTENT=0

# YummyAnime API (api.yani.tv): создайте приложение на https://yummyani.me/dev/applications
# YUMMY_APPLICATION_TOKEN=ваш_X_Application_токен
# Интервал фоновой синхронизации списков Yummy (секунды, не меньше 60). По умолчанию 600.
# YUMMY_SYNC_INTERVAL_SEC=600
# Необязательно: ID роли модераторов бота (доступ к /admin и /admin без права «Администратор»).
# DISCORD_ADMIN_ROLE_ID=123456789012345678
